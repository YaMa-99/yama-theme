  "tokenColors": [
    // --- --- --- --- --- ---
    // --- Палитра цветов ---
    // --- --- --- --- --- ---
    // #0f172a - черный, основной цвет текста
    // #979797 - серый, приглушаем "все не нужное" + выделяем комментарии
    // #0369a1 - синий, выделяем функции
    // #059669 - зеленый, выделяем строки
    // #b45309 - оранжевый, выделяем константы и типы ТС
    // "fontStyle": "bold" - дополнительно используется выделение жирным шрифтом
    // --- --- --- --- --- ---
    // --- --- --- --- --- ---

    // --- --- --- --- --- ---
    // --- JS, TS ---
    // --- --- --- --- --- ---
    // Черный цвет
    {
      "scope": [
        "meta.template.expression",
      ],
      "settings": {
        "foreground": "#0f172a",
      }
    },
    {
      "scope": [
        "variable.other.constant.object.property",
        "variable.other.constant.property"
      ],
      "settings": {
        "foreground": "#0f172a",
        "fontStyle": ""
      }
    },
    // Жирный текст
    {
      "name": "Variable",
      "scope": [
        "variable.language.this",
        "variable.other.constant",
        "variable.other.global",
        "variable.other.readwrite.global",
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    // Серый цвет
    {
      "scope": [
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "storage.type.function.arrow",
        "punctuation.accessor",
        "punctuation.definition.brace",
        "punctuation.definition.bracket",
        "punctuation.definition.paren",
        "punctuation.definition.group",
        "punctuation.definition.block",
        "punctuation.definition.function",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "punctuation.separator.arrow",
        "punctuation.separator.comma",
        "punctuation.terminator.statement",
        "punctuation.separator.parameter",
        "punctuation.separator.key-value",
        "punctuation.definition.string.template.begin",
        "punctuation.definition.string.template.end",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end",
        "meta.brace.round",
        "meta.brace.square",
      ],
      "settings": {
        "foreground": "#979797"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#979797"
      }
    },
    // Синий цвет
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#0369a1",
        "fontStyle": ""
      }
    },
    // Зеленый цвет
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "text.html.vue string"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    // Оранжевый цвет 
    {
      "name": "Number, Constant",
      "scope": [
        "variable.other.constant.object",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Class, Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "Js doc",
      "scope": [
        "storage.type.class.jsdoc"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "italic bold"
      }
    },
    // --- --- --- ---

    // --- --- --- --- --- ---
    // --- CSS, SCSS ---
    // --- --- --- --- --- ---
    // Черный цвет
    {
      "name": "Scss string",
      "scope": [
        "string.quoted.double.scss"
      ],
      "settings": {
        "foreground": "#0f172a",
      }
    },
    {
      "scope": [
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#0f172a",
        "fontStyle": ""
      }
    },
    // Серый цвет
    {
      "name": "Css styles",
      "scope": [
        "support.type.property-name.css",
        "entity.name.tag.reference.scss",
        "punctuation.terminator.rule.scss",
        "punctuation.section.function.begin.bracket.round.css",
        "punctuation.section.function.end.bracket.round.css",
        "punctuation.section.property-list.begin.bracket.curly.scss",
        "punctuation.section.property-list.end.bracket.curly.scss",
        "meta.at-rule.forward.scss"
      ],
      "settings": {
        "foreground": "#979797"
      }
    },
    // Зеленый цвет
    {
      "name": "Css variable",
      "scope": [
        "variable.scss"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    // Оранжевый цвет 
    {
      "scope": [
        "constant.numeric.css",
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": ""
      }
    },
    // --- --- --- ---

    // --- --- --- --- --- ---
    // --- HTML ---
    // --- --- --- --- --- ---
    // Серый цвет
    {
      "name": "Text",
      "scope": [
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#979797",
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.attribute-shorthand.bind.html.vue",
        "punctuation.definition.interpolation.begin.html.vue",
        "punctuation.definition.interpolation.end.html.vue",
        "punctuation.definition.string.begin.html.vue",
        "punctuation.definition.string.end.html.vue",
        "punctuation.attribute-shorthand.event.html.vue",
        "punctuation.separator.key-value.html.vue",
      ],
      "settings": {
        "foreground": "#979797",
        "fontStyle": ""
      }
    },
    {
      "name": "Section SFC",
      "scope": [
        "entity.name.tag.template.html.vue",
        "entity.name.tag.script.html.vue",
        "entity.name.tag.style.html.vue"

      ],
      "settings": {
        "foreground": "#979797",
        "fontStyle": ""
      }
    },
    // Черный цвет
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#0f172a",
      }
    },
    {
      "name": "Variable",
      "scope": [
        "source.ts.embedded.html.vue"
      ],
      "settings": {
        "foreground": "#0f172a",
        "fontStyle": ""
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "fontStyle": ""
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator.expression.in.ts",
        "keyword.operator.new.ts"
      ],
      "settings": {
        "foreground": "#0f172a",
        "fontStyle": ""
      }
    },
    // Зеленый цвет
    {
      "name": "String",
      "scope": [
        "string.quoted.double.html"
      ],
      "settings": {
        "foreground": "#059669",
        "fontStyle": ""
      }
    },
    // Жирный текст
    {
      "name": "Tag custom",
      "scope": [
        "meta.tag.custom.start.html",
        "meta.tag.custom.end.html",
        "meta.tag.other.unrecognized.html.derivative",
        "meta.tag.structure.slot.start.html"
      ],
      "settings": {
        "foreground": "#0f172a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Directive",
      "scope": [
        "keyword.control.conditional.vue",
        "keyword.control.loop.vue",
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "bold"
      }
    },
    // Оранжевый цвет 
    {
      "name": "Attribute, Directive",
      "scope": [
        "meta.attribute",
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": ""
      }
    },
    // --- --- --- ---

    // --- --- --- --- --- ---
    // --- JSON ---
    // --- --- --- --- --- ---
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.json.comments"
      ],
      "settings": {
        "foreground": "#0f172a",
      }
    },
    {
      "name": "JSON String",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
      "name": "JSON Number",
      "scope": [
        "constant.numeric.json"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON Boolean",
      "scope": [
        "constant.language.json"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": ""
      }
    },
    {
      "name": "JSON Punctuation",
      "scope": [
        "punctuation.definition.json",
        "punctuation.definition.dictionary.begin.json",
        "punctuation.definition.dictionary.end.json",
        "punctuation.separator.dictionary.pair.json",
        "punctuation.separator.dictionary.key-value.json",
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json"
      ],
      "settings": {
        "foreground": "#979797"
      }
    },

    // --- --- --- --- --- ---
    // --- Markdown ---
    // --- --- --- --- --- ---
    {
      "name": "Markdown Heading",
      "scope": [
        "markdown.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#0f172a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Heading Punctuation",
      "scope": [
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#979797",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown List",
      "scope": [
        "markdown.list",
        "punctuation.definition.list.markdown"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markdown.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#0369a1"
      }
    },
    {
      "name": "Markdown Link Text",
      "scope": [
        "markdown.link.label"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
