  "tokenColors": [
    // --- --- --- --- --- ---
    // --- Палитра цветов (Dark) ---
    // --- --- --- --- --- ---
    // #e2e8f0 - белый, основной цвет текста
    // #64748b - серый, приглушаем "все не нужное" + выделяем комментарии
    // #60a5fa - синий, выделяем функции
    // #4ade80 - зеленый, выделяем строки
    // #fbbf24 - желтый/оранжевый, выделяем константы и типы
    // "fontStyle": "bold" - дополнительно используется выделение жирным шрифтом
    // --- --- --- --- --- ---
    // --- --- --- --- --- ---

    // --- JS, TS ---
    {
      "scope": [
        "meta.template.expression",
      ],
      "settings": {
        "foreground": "#e2e8f0",
      }
    },
    {
      "scope": [
        "variable.other.constant.object.property",
        "variable.other.constant.property"
      ],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": ""
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable.other.constant",
        "variable.other.global",
        "variable.other.readwrite.global",
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "storage.type.function.arrow",
        "punctuation.accessor",
        "punctuation.definition.brace",
        "punctuation.definition.bracket",
        "punctuation.definition.paren",
        "punctuation.definition.group",
        "punctuation.definition.block",
        "punctuation.definition.function",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "punctuation.separator.arrow",
        "punctuation.separator.comma",
        "punctuation.terminator.statement",
        "punctuation.separator.parameter",
        "punctuation.definition.string.template.begin",
        "punctuation.definition.string.template.end",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end",
        "meta.brace.round",
      ],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#64748b"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#60a5fa",
        "fontStyle": ""
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted.single",
        "string.quoted.double",
        "text.html.vue string"
      ],
      "settings": {
        "foreground": "#4ade80"
      }
    },
    {
      "name": "Number, Constant",
      "scope": [
        "variable.other.constant.object",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Class, Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Js doc",
      "scope": [
        "storage.type.class.jsdoc"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic bold"
      }
    },
    // --- --- --- ---

    // --- CSS, SCSS ---
    {
      "name": "Scss string",
      "scope": [
        "string.quoted.double.scss"
      ],
      "settings": {
        "foreground": "#e2e8f0",
      }
    },
    {
      "scope": [
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": ""
      }
    },
    {
      "name": "Css styles",
      "scope": [
        "support.type.property-name.css",
        "entity.name.tag.reference.scss",
        "punctuation.terminator.rule.scss",
        "punctuation.section.function.begin.bracket.round.css",
        "punctuation.section.function.end.bracket.round.css",
        "punctuation.section.property-list.begin.bracket.curly.scss",
        "punctuation.section.property-list.end.bracket.curly.scss",
        "meta.at-rule.forward.scss"
      ],
      "settings": {
        "foreground": "#64748b"
      }
    },
    {
      "name": "Css variable",
      "scope": [
        "variable.scss"
      ],
      "settings": {
        "foreground": "#4ade80"
      }
    },
    {
      "scope": [
        "constant.numeric.css",
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": ""
      }
    },
    // --- --- --- ---

    // --- HTML ---
    {
      "name": "Text",
      "scope": [
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#64748b",
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.attribute-shorthand.bind.html.vue",
        "punctuation.definition.interpolation.begin.html.vue",
        "punctuation.definition.interpolation.end.html.vue",
        "punctuation.definition.string.begin.html.vue",
        "punctuation.definition.string.end.html.vue",
        "punctuation.attribute-shorthand.event.html.vue",
        "punctuation.separator.key-value.html.vue",
      ],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": ""
      }
    },
    {
      "name": "Section SFC",
      "scope": [
        "entity.name.tag.template.html.vue",
        "entity.name.tag.script.html.vue",
        "entity.name.tag.style.html.vue"

      ],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": ""
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#e2e8f0",
      }
    },
    {
      "name": "Variable",
      "scope": [
        "source.ts.embedded.html.vue"
      ],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": ""
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "fontStyle": ""
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator.expression.in.ts",
        "keyword.operator.new.ts"
      ],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": ""
      }
    },
    {
      "name": "String",
      "scope": [
        "string.quoted.double.html"
      ],
      "settings": {
        "foreground": "#4ade80",
        "fontStyle": ""
      }
    },
    {
      "name": "Tag custom",
      "scope": [
        "meta.tag.custom.start.html",
        "meta.tag.custom.end.html",
        "meta.tag.other.unrecognized.html.derivative",
        "meta.tag.structure.slot.start.html"
      ],
      "settings": {
        "foreground": "#e2e8f0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Directive",
      "scope": [
        "keyword.control.conditional.vue",
        "keyword.control.loop.vue",
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Attribute, Directive",
      "scope": [
        "meta.attribute",
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": ""
      }
    },
    // --- --- --- ---

    // --- JSON ---
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.json.comments"
      ],
      "settings": {
        "foreground": "#e2e8f0",
      }
    },
    {
      "name": "JSON String",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#4ade80"
      }
    },
    {
      "name": "JSON Number",
      "scope": [
        "constant.numeric.json"
      ],
      "settings": {
        "foreground": "#fbbf24",
